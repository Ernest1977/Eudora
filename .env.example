# ============================================
# Eudora Conseil & Relooking — Variables d'environnement
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs
# cp .env.example .env

# ---- App ----
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=CHANGEZ-MOI-avec-une-cle-aleatoire-de-64-caracteres
JWT_SECRET_KEY=CHANGEZ-MOI-avec-une-autre-cle-aleatoire

# ---- Base de données PostgreSQL ----
POSTGRES_USER=eudora
POSTGRES_PASSWORD=CHANGEZ-MOI-mot-de-passe-fort
POSTGRES_DB=eudora_db
DATABASE_URL=postgresql://eudora:CHANGEZ-MOI-mot-de-passe-fort@db:5432/eudora_db

# ---- Email (SMTP) ----
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-application
MAIL_DEFAULT_SENDER=contact@eudora-conseil.fr

# ---- CORS ----
CORS_ORIGINS=https://eudora-conseil.fr,https://www.eudora-conseil.fr

# ---- Domaine (pour Nginx / SSL) ----
DOMAIN=eudora-conseil.fr
